<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#E3F2FD"
    android:gravity="center_horizontal">

    <TextView
        android:id="@+id/textFragmentTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="📋 Список задач"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#1565C0"
        android:layout_marginBottom="24dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Отметьте выполненные задачи:"
        android:textSize="16sp"
        android:textColor="#424242"
        android:layout_marginBottom="16dp"/>

    <CheckBox
        android:id="@+id/task1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="✅ Изучить LinearLayout"
        android:textSize="16sp"
        android:layout_marginBottom="8dp"/>

    <CheckBox
        android:id="@+id/task2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="✅ Реализовать Serializable"
        android:textSize="16sp"
        android:layout_marginBottom="8dp"/>

    <CheckBox
        android:id="@+id/task3"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="✅ Настроить Activity Result API"
        android:textSize="16sp"
        android:layout_marginBottom="24dp"/>

    <Button
        android:id="@+id/btnToSecond"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="→ Перейти к выполненным"
        android:backgroundTint="#1976D2"
        android:textColor="#FFFFFF"/>

</LinearLayout>