<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    tools:context=".MainActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="@color/background_light">

        <TextView
            android:id="@+id/titleText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/title_text"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:gravity="center"
            android:layout_marginBottom="16dp"/>

        <ImageView
            android:id="@+id/myImage"
            android:layout_width="150dp"
            android:layout_height="125dp"
            android:src="@drawable/enot"
            android:contentDescription="@string/image_desc"
            android:layout_gravity="center"
            android:layout_marginBottom="16dp"/>

        <EditText
            android:id="@+id/editName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/hint_name"
            android:inputType="textPersonName"
            android:background="@color/input_background"
            android:padding="12dp"
            android:layout_marginBottom="8dp"/>

        <EditText
            android:id="@+id/editSurname"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/hint_surname"
            android:inputType="textPersonName"
            android:background="@color/input_background"
            android:padding="12dp"
            android:layout_marginBottom="8dp"/>

        <EditText
            android:id="@+id/editGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/hint_group"
            android:inputType="text"
            android:background="@color/input_background"
            android:padding="12dp"
            android:layout_marginBottom="8dp"/>

        <EditText
            android:id="@+id/editAge"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/hint_age"
            android:inputType="number"
            android:background="@color/input_background"
            android:padding="12dp"
            android:layout_marginBottom="8dp"/>

        <EditText
            android:id="@+id/editGrade"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/hint_grade"
            android:inputType="numberDecimal"
            android:background="@color/input_background"
            android:padding="12dp"
            android:layout_marginBottom="16dp"/>

        <!-- Разделитель: Практика 5: SharedPreferences -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🔐 Практика 5: SharedPreferences"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/primary_color"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="8dp"/>

        <EditText
            android:id="@+id/editUsername"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Введите имя пользователя"
            android:inputType="textPersonName"
            android:background="@color/input_background"
            android:padding="12dp"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btnSavePrefs"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="💾 Сохранить имя"
            android:backgroundTint="@color/primary_color"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btnLoadPrefs"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📥 Загрузить имя"
            android:backgroundTint="@color/primary_color"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btnUpdatePrefs"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="✏️ Изменить имя"
            android:backgroundTint="@color/primary_color"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btnDeletePrefs"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🗑️ Удалить имя"
            android:backgroundTint="@color/error_color"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/textPrefsResult"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Результат: —"
            android:textSize="16sp"
            android:textColor="@color/text_primary"
            android:layout_marginTop="16dp"
            android:gravity="center"/>

        <!-- Разделитель: Практика 5: База данных (SQLite) -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🗄️ Практика 5: База данных (SQLite)"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/primary_color"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="8dp"/>

        <EditText
            android:id="@+id/editProductName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Название товара"
            android:inputType="text"
            android:background="@color/input_background"
            android:padding="12dp"
            android:layout_marginBottom="4dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="4dp">

            <EditText
                android:id="@+id/editProductPrice"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Цена"
                android:inputType="numberDecimal"
                android:background="@color/input_background"
                android:padding="12dp"/>

            <EditText
                android:id="@+id/editProductQty"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Кол-во"
                android:inputType="number"
                android:background="@color/input_background"
                android:padding="12dp"
                android:layout_marginStart="4dp"/>
        </LinearLayout>

        <EditText
            android:id="@+id/editProductCategory"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Категория"
            android:inputType="text"
            android:background="@color/input_background"
            android:padding="12dp"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <Button
                android:id="@+id/btnDbAdd"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="➕ Добавить"
                android:backgroundTint="@color/primary_color"
                android:layout_marginEnd="4dp"/>

            <Button
                android:id="@+id/btnDbFind"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="🔍 Найти"
                android:backgroundTint="@color/primary_color"
                android:layout_marginEnd="4dp"/>

            <Button
                android:id="@+id/btnDbUpdate"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="✏️ Изменить"
                android:backgroundTint="@color/primary_color"/>
        </LinearLayout>

        <Button
            android:id="@+id/btnDbDelete"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🗑️ Удалить по ID"
            android:backgroundTint="@color/error_color"
            android:layout_marginBottom="8dp"/>

        <EditText
            android:id="@+id/editDeleteId"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="ID для удаления"
            android:inputType="number"
            android:background="@color/input_background"
            android:padding="12dp"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/textDbResult"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Результат: —"
            android:textSize="14sp"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📋 Все товары:"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp"/>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="150dp"
            android:background="@color/input_background"
            android:padding="8dp">

            <TextView
                android:id="@+id/textDbList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Список пуст"
                android:textSize="14sp"/>
        </ScrollView>

        <Button
            android:id="@+id/btnSendProgrammatic"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/btn_programmatic"
            android:onClick="sendMessageProgrammatic"
            android:backgroundTint="@color/primary_color"
            android:textColor="@color/button_text"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btnSendDeclarative"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/btn_declarative"
            android:backgroundTint="@color/secondary_color"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btnToLinear"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Перейти к LinearLayout"
            android:backgroundTint="@color/primary_color"
            android:textColor="@color/button_text"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btnStartChain"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Начать цепочку (3 Activity)"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btnStaticFragment"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Фрагменты: Статически"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btnDynamicFragment"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Фрагменты: Динамически"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btnContainerViewFragment"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Фрагменты: FragmentContainerView"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btnScrollView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📜 ScrollView + EditText"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btnCategoryList"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📦 ListView: Категории продуктов"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btnRecyclerView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📋 RecyclerView: Товары с картинками"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btnSpinner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Spinner: Выбор города"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btnNavigationDrawer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Navigation Drawer + Фрагменты"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btnBottomBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="BottomBar + ActionBar + Фрагменты"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Практика 4: Сервис"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/primary_color"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btnStartService"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="▶Запустить сервис"
            android:backgroundTint="@color/primary_color"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btnStopService"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="⏹ Остановить сервис"
            android:backgroundTint="@color/error_color"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Практика 4: Диалоги"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/primary_color"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btnAlertDialog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="⚠AlertDialog"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btnDatePicker"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="DatePickerDialog"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btnTimePicker"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="TimePickerDialog"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btnCustomDialog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Custom Dialog (Fragment)"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/textDateTime"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Дата и время: не выбрано"
            android:textSize="16sp"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="16dp"
            android:gravity="center"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Практика 4: Потоки (Thread)"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/primary_color"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btnThreadBlock"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Блокировка UI (20 сек)"
            android:backgroundTint="@color/error_color"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btnThreadAsync"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Асинхронный поток (20 сек)"
            android:backgroundTint="@color/primary_color"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/textThreadStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Статус: ожидание"
            android:textSize="16sp"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="16dp"
            android:gravity="center"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Практика 4: Handler"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/primary_color"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btnHandler"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Запустить Handler (50 тиков)"
            android:backgroundTint="@color/primary_color"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/textHandlerStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Handler: ожидание"
            android:textSize="16sp"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="16dp"
            android:gravity="center"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Практика 4: WorkManager"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/primary_color"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btnWorkSequential"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="3 задачи последовательно"
            android:backgroundTint="@color/primary_color"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btnWorkParallel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="2 задачи параллельно"
            android:backgroundTint="@color/primary_color"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btnWorkApi"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Загрузка из API"
            android:backgroundTint="@color/primary_color"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/textWorkStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="WorkManager: ожидание"
            android:textSize="16sp"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="16dp"
            android:gravity="center"/>

        <ImageView
            android:id="@+id/imageApi"
            android:layout_width="200dp"
            android:layout_height="200dp"
            android:layout_gravity="center"
            android:scaleType="centerCrop"
            android:background="@color/input_background"
            android:contentDescription="Загруженное изображение"/>

    </LinearLayout>
</ScrollView>