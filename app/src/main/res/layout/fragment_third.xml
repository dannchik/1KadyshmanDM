<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#F3E5F5"
    android:gravity="center_horizontal">

    <TextView
        android:id="@+id/textFragmentTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🎯 Цели"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#7B1FA2"
        android:layout_marginBottom="24dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Нажимайте, чтобы добавить цель:"
        android:textSize="16sp"
        android:textColor="#424242"
        android:layout_marginBottom="16dp"/>

    <Button
        android:id="@+id/btnIncrement"
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:text="➕\nДобавить цель"
        android:textSize="18sp"
        android:backgroundTint="#9C27B0"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="24dp"/>

    <TextView
        android:id="@+id/counterText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Достигнуто целей: 0"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#7B1FA2"
        android:layout_marginBottom="32dp"/>

    <Button
        android:id="@+id/btnFinish"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="✅ Завершить практику"
        android:backgroundTint="#AB47BC"
        android:layout_marginBottom="8dp"/>

    <Button
        android:id="@+id/btnBack"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="← Назад к прогрессу"
        android:backgroundTint="#CE93D8"/>

</LinearLayout>